# 复制为 .env 后填值；.env 已 gitignored，绝不提交真实密钥（见 docs/08）

# ---- Bangumi ----
# 强制 User-Agent，通用 UA 会被拒；把 repo-url 换成你自己的
BANGUMI_USER_AGENT=otomo-dev/otomo/0.1 (+https://github.com/yourname/otomo)
# 个人令牌：只读开发可留空，写操作（改收藏/进度）才必填；可在 bgm.tv 个人令牌页吊销/重签
# 这是单机开发 token，不会自动变成 OAuth 登录；前端可用“本地 Token”按钮绑定当前浏览器会话。
BANGUMI_TOKEN=
BANGUMI_API_BASE=https://api.bgm.tv
# OAuth 多用户登录：需要在 https://bgm.tv/dev/app 单独创建应用，回调地址需和后台配置完全一致。
BANGUMI_OAUTH_CLIENT_ID=
BANGUMI_OAUTH_CLIENT_SECRET=
BANGUMI_OAUTH_REDIRECT_URI=http://localhost:8000/auth/bangumi/callback
FRONTEND_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Auth/session：本地默认 SQLite + 自动生成 Fernet key；生产多实例必须显式配置 AUTH_ENCRYPTION_KEY 且共用 DB。
AUTH_STORE_BACKEND=sqlite
AUTH_STORE_PATH=cache/auth/auth.sqlite3
AUTH_ENCRYPTION_KEY=
SESSION_COOKIE_NAME=otomo_session
CSRF_COOKIE_NAME=otomo_csrf
CSRF_HEADER_NAME=x-otomo-csrf
SESSION_STORE_PATH=cache/sessions.sqlite3
COOKIE_SECURE=false
CSRF_PROTECTION_ENABLED=true
SESSION_TTL_SECONDS=2592000

# ---- LLM（OpenAI 兼容，默认 DeepSeek，国内直连免代理）----
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash

# ---- VLM（可选：route_image_source / OCR / 视觉推荐，只调现成视觉模型）----
VLM_BASE_URL=
VLM_API_KEY=
VLM_MODEL=
# 可选：例如 aliyun-bailian；当前只用于配置说明/trace，不硬编码供应商
VLM_PROVIDER=
# 可选：给 Qwen-VL/OCR 类模型的额外提示，如“优先识别画面中文字、字幕、番剧标题牌”
VLM_OCR_HINT=

# ---- Image source search（可选：SauceNAO 以图搜图；不填则只走 trace.moe / 导航入口）----
SAUCENAO_API_KEY=
# 可选付费兜底：SerpApi Google Reverse Image；只对公网图片 URL 生效，上传图不会外传到 SerpApi。
SERPAPI_API_KEY=

# ---- Uploads（截图上传；文件落 cache/uploads，已 gitignore）----
UPLOAD_MAX_IMAGE_BYTES=6291456
BROWSER_FETCH_TIMEOUT_MS=15000
BROWSER_FETCH_MAX_SCROLLS=3

# ---- Trajectory / pre-RL data（本地 JSONL，已 gitignore）----
TRAJECTORY_CAPTURE_ENABLED=true
TRAJECTORY_STORE_OBSERVATIONS=true
CLAIM_AUTO_REVISION_ENABLED=true
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
WEEKLY_SCHEDULER_ENABLED=true
WEEKLY_SCHEDULER_INTERVAL_SECONDS=900
WEEKLY_WEBHOOK_TIMEOUT=8
NOTIFICATION_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ---- Agent ----
AGENT_MAX_ITERS=8
HTTP_TIMEOUT=30
CACHE_TTL=300
