# 复制为 .env 后填值；.env 已 gitignored，绝不提交真实密钥（见 docs/08）

# ---- Bangumi ----
# 强制 User-Agent，通用 UA 会被拒；把 repo-url 换成你自己的
BANGUMI_USER_AGENT=otomo-dev/otomo/0.1 (+https://github.com/yourname/otomo)
# 个人令牌：只读开发可留空，写操作（改收藏/进度）才必填；可在 bgm.tv 个人令牌页吊销/重签
BANGUMI_TOKEN=
BANGUMI_API_BASE=https://api.bgm.tv

# ---- LLM（OpenAI 兼容，默认 DeepSeek，国内直连免代理）----
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash

# ---- VLM（可选：截图识番，只调现成视觉模型；不填则 identify_acgn_screenshot 优雅报未配置）----
VLM_BASE_URL=
VLM_API_KEY=
VLM_MODEL=
# 可选：例如 aliyun-bailian；当前只用于配置说明/trace，不硬编码供应商
VLM_PROVIDER=
# 可选：给 Qwen-VL/OCR 类模型的额外提示，如“优先识别画面中文字、字幕、番剧标题牌”
VLM_OCR_HINT=

# ---- Uploads（截图上传；文件落 cache/uploads，已 gitignore）----
UPLOAD_MAX_IMAGE_BYTES=6291456

# ---- Trajectory / pre-RL data（本地 JSONL，已 gitignore）----
TRAJECTORY_CAPTURE_ENABLED=true
TRAJECTORY_STORE_OBSERVATIONS=true

# ---- Agent ----
AGENT_MAX_ITERS=8
HTTP_TIMEOUT=30
CACHE_TTL=300
