# Copy selected values into backend/.env on the server.
# Never commit real secrets.

FRONTEND_BASE_URL=https://your-domain.example
CORS_ALLOWED_ORIGINS=https://your-domain.example
BANGUMI_OAUTH_REDIRECT_URI=https://your-domain.example/auth/bangumi/callback

COOKIE_SECURE=true
CSRF_PROTECTION_ENABLED=true
AUTH_STORE_BACKEND=sqlite
AUTH_STORE_PATH=cache/auth/auth.sqlite3
SESSION_STORE_PATH=cache/sessions.sqlite3
AUTH_ENCRYPTION_KEY=generate-a-fixed-fernet-key-and-keep-it-safe

WEEKLY_SCHEDULER_ENABLED=false
WEEKLY_SCHEDULER_INTERVAL_SECONDS=900

RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT_PER_MINUTE=10
RATE_LIMIT_CHAT_PER_HOUR=30
RATE_LIMIT_UPLOADS_PER_MINUTE=5
ANONYMOUS_SESSION_TURN_LIMIT=8
DAILY_TOKEN_BUDGET_USER=200000
DAILY_TOKEN_BUDGET_GLOBAL=1000000
QUOTA_STORE_PATH=cache/quota.json

NOTIFICATION_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
