# 拷进服务器上的 backend/.env。别提交真实密钥。
# 下面示例用 nip.io 免域名方案：把 1.2.3.4 换成你服务器的公网 IP（点换成横线）。

# —— 公网 URL（三选一）——
# ① nip.io 免域名：https://1-2-3-4.nip.io   （Caddy 会自动申请真 HTTPS 证书）
# ② 有域名：https://otomo.example.com
# ③ Cloudflare Quick Tunnel：填 CF 打印的 https://xxx.trycloudflare.com（每次重启会变，OAuth 不稳）
FRONTEND_BASE_URL=https://1-2-3-4.nip.io
CORS_ALLOWED_ORIGINS=https://1-2-3-4.nip.io
BANGUMI_OAUTH_REDIRECT_URI=https://1-2-3-4.nip.io/auth/bangumi/callback
# Bangumi 开发者后台的「回调地址」必须和上面这行完全一致

COOKIE_SECURE=true
CSRF_PROTECTION_ENABLED=true
AUTH_STORE_BACKEND=sqlite
AUTH_STORE_PATH=cache/auth/auth.sqlite3
SESSION_STORE_PATH=cache/sessions.sqlite3
SHARE_STORE_PATH=cache/share_snapshots.sqlite3
SUBSCRIPTION_STORE_PATH=cache/subscriptions.sqlite3
# 固定的 Fernet key（生成：python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"）
# 换了这个 key，所有用户登录态失效——务必固定并妥善保存
AUTH_ENCRYPTION_KEY=generate-a-fixed-fernet-key-and-keep-it-safe

# 调度器：API 进程一律 false；由 scheduler 服务统一开（见 docker-compose）
WEEKLY_SCHEDULER_ENABLED=false
SUBSCRIPTION_SCHEDULER_ENABLED=false

RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT_PER_MINUTE=10
RATE_LIMIT_CHAT_PER_HOUR=30
RATE_LIMIT_UPLOADS_PER_MINUTE=5
RATE_LIMIT_SHARE_IP_PER_HOUR=60
RATE_LIMIT_SHARE_USER_PER_HOUR=20
ANONYMOUS_SESSION_TURN_LIMIT=8
DAILY_TOKEN_BUDGET_USER=1500000
DAILY_TOKEN_BUDGET_GLOBAL=8000000
QUOTA_STORE_PATH=cache/quota.json

# LLM / VLM（必填，用你的 key）
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash

NOTIFICATION_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
